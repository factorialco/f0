+function go(
+  setSearch: ReturnType<typeof useSearchParams>[1],
+  next: Record<string, string | null>
+) {
+  setSearch((prev) => {
+    const sp = new URLSearchParams(prev)
+    Object.entries(next).forEach(([k, v]) => {
+      if (v === null) sp.delete(k)
+      else sp.set(k, v)
+    })
+    return sp
+  })
