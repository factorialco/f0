+              >
+                {action === "create" && "Create"}
+                {action === "publish" && "Confirm"}
+                {action === "delete" && "Delete"}
+                {action === "settings" && "Save"}
+              </button>
+            </div>
+          </div>
+        </div>
+      )}
+    </>
+  )
+}
