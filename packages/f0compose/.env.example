# f0compose AI chat configuration.
#
# Defaults point at the local factorial-agent runtime via Traefik (HTTPS,
# no port) — the same URL f0-react Storybook uses. Going direct to the
# Mastra port (:4111) bypasses Traefik and produces CORS errors.
# Override here when you're not running the agent locally or want to
# point at a deployed environment.
#
# Start the local agent with:  cd ../../factorial-agent && pnpm dev

VITE_AGENT_URL=https://mastra.local.factorial.dev/copilotkit
VITE_AGENT_NAME=one-workflow
