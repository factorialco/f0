{
  "name": "@factorialco/f0-react-native",
  "version": "0.58.1",
  "type": "module",
  "description": "React Native components for F0 Design System",
  "main": "expo-router/entry",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "source": "./src/index.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "react-native": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./icons": {
      "types": "./src/icons/index.ts",
      "import": "./src/icons/index.ts",
      "require": "./src/icons/index.ts",
      "react-native": "./src/icons/index.ts",
      "default": "./src/icons/index.ts"
    },
    "./icons/app": {
      "types": "./src/icons/app/index.ts",
      "import": "./src/icons/app/index.ts",
      "require": "./src/icons/app/index.ts",
      "react-native": "./src/icons/app/index.ts",
      "default": "./src/icons/app/index.ts"
    },
    "./icons/modules": {
      "types": "./src/icons/modules/index.ts",
      "import": "./src/icons/modules/index.ts",
      "require": "./src/icons/modules/index.ts",
      "react-native": "./src/icons/modules/index.ts",
      "default": "./src/icons/modules/index.ts"
    },
    "./src/icons/app": {
      "types": "./src/icons/app/index.ts",
      "import": "./src/icons/app/index.ts",
      "require": "./src/icons/app/index.ts",
      "react-native": "./src/icons/app/index.ts",
      "default": "./src/icons/app/index.ts"
    },
    "./package.json": "./package.json",
    "./styles": "./lib/module/styles/index.css",
    "./expo-router/entry": {
      "import": "./expo-router/entry.js",
      "require": "./expo-router/entry.js",
      "react-native": "./expo-router/entry.js",
      "default": "./expo-router/entry.js"
    }
  },
  "files": [
    "src",
    "lib"
  ],
  "scripts": {
    "prebuild": "node scripts/set-main.cjs build",
    "build": "node scripts/build-with-fix.cjs",
    "build:dev": "SKIP_TYPE_VALIDATION=true node scripts/build-with-fix.cjs --skip-type-validation",
    "postbuild": "node scripts/set-main.cjs dev && test -d lib/typescript/react-native/package && rm -rf lib/typescript/react-native/package || true",
    "dev:setup": "node scripts/set-main.cjs dev",
    "prepare": "node scripts/build-with-fix.cjs",
    "lint": "sh -c 'oxlint \"${@:-src/**/*}\" --max-warnings 0' --",
    "lint:fix": "sh -c 'oxlint \"${@:-src/**/*}\" --fix --max-warnings 0' --",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --coverageReporters=text --coverageReporters=lcov",
    "start:dev": "pnpm expo start -c",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-icons:check": "node scripts/generate-icons.mjs --check",
    "format": "sh -c 'oxfmt \"${@:-src/}\"' --",
    "format:check": "sh -c 'oxfmt --check \"${@:-src/}\"' --",
    "tsc": "tsc --noEmit"
  },
  "keywords": [
    "factorial",
    "design-system",
    "react-native",
    "components"
  ],
  "author": "Factorial",
  "license": "MIT",
  "peerDependencies": {
    "date-fns": "^3.6.0",
    "expo-image": "*",
    "expo-blur": "*",
    "expo-clipboard": "*",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=4.1.1 <5.0.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-svg": "^15.12.1",
    "react-native-worklets": ">=0.5.1 <1.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.9.0",
    "twemoji-parser": "^14.0.0"
  },
  "dependencies": {
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-typescript": "^7.28.5",
    "@expo/ui": "~56.0.18",
    "@expo/vector-icons": "^15.1.1",
    "@react-native/jest-preset": "0.85.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@svgr/cli": "^8.1.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.16",
    "@types/react": "~19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/twemoji-parser": "^13.1.4",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "^56.0.15",
    "eslint-plugin-react-refresh": "^0.4.26",
    "expo": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "glob": "^11.0.0",
    "jest": "^30.2.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.33.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.40.12",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "react-test-renderer": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.2",
    "uniwind": "^1.9.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true,
          "configFile": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
